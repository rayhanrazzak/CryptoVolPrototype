# Kalshi API credentials (optional - app works with public endpoints first)
# KALSHI_API_KEY=your_api_key_here
# KALSHI_PRIVATE_KEY_PATH=./kalshi_private_key.pem

# Deribit uses public endpoints - no credentials needed

# Optional: Google Gemini API key for trade synthesis (free tier)
# Get a free key at https://aistudio.google.com/apikey
# GEMINI_API_KEY=your_gemini_api_key_here

# Optional: override default settings
# BTC_SPOT_SOURCE=coingecko
# REFRESH_INTERVAL_SECONDS=30
